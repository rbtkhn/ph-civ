{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "civ-ph Media Inventory Item",
  "type": "object",
  "required": [
    "source_id",
    "bucket",
    "item_title",
    "source_url",
    "source_name",
    "item_type",
    "what_to_notice",
    "lecture_connection",
    "limit_or_caution",
    "curator_fit_score",
    "curator_note"
  ],
  "properties": {
    "source_id": {
      "type": "string",
      "pattern": "^(civ|gb|geo|gt|sh)-[0-9]{2}$"
    },
    "bucket": {
      "type": "string",
      "enum": [
        "entry_object",
        "context_anchor",
        "primary_object_or_text",
        "comparison_object",
        "pressure_or_structure",
        "limit_or_caution"
      ]
    },
    "curator_fit_score": {
      "type": "integer",
      "minimum": 1,
      "maximum": 5
    }
  }
}
