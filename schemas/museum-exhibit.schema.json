{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Predictive History Museum Exhibit",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "exhibit_id",
    "chapter_id",
    "surface",
    "title",
    "status",
    "visitor_path",
    "artifact_ids"
  ],
  "properties": {
    "exhibit_id": {
      "type": "string",
      "pattern": "^[a-z]+-[0-9]{2,3}-exhibit$"
    },
    "chapter_id": {
      "type": "string",
      "pattern": "^[a-z]+-[0-9]{2,3}$"
    },
    "surface": {
      "type": "string",
      "enum": [
        "ph-civ",
        "ph-apo"
      ]
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "planned",
        "in_curation",
        "routed_draft",
        "reviewed",
        "published"
      ]
    },
    "visitor_path": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": [
          "entrance_artifact",
          "context_room",
          "primary_artifacts_and_texts",
          "comparison_artifacts",
          "pressure_systems",
          "caution_room"
        ]
      }
    },
    "artifact_ids": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "what_changes_here": {
      "type": "string"
    },
    "curator_summary": {
      "type": "string"
    },
    "rights_review_note": {
      "type": "string"
    }
  }
}
