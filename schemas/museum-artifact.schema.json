{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Predictive History Museum Artifact",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_id",
    "chapter_id",
    "room",
    "title",
    "artifact_type",
    "local_vault_path",
    "shared_cloud_path",
    "provenance",
    "source_name",
    "rights_status",
    "what_to_notice",
    "lecture_connection",
    "limit_or_caution",
    "curator_note"
  ],
  "properties": {
    "artifact_id": {
      "type": "string",
      "pattern": "^[a-z0-9]+-[a-z0-9-]+-[0-9]{2,3}$"
    },
    "chapter_id": {
      "type": "string",
      "pattern": "^[a-z]+-[0-9]{2,3}$"
    },
    "room": {
      "type": "string",
      "enum": [
        "entrance_artifact",
        "context_room",
        "primary_artifacts_and_texts",
        "comparison_artifacts",
        "pressure_systems",
        "caution_room"
      ]
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "artifact_type": {
      "type": "string",
      "enum": [
        "artwork",
        "artifact",
        "object",
        "text",
        "manuscript",
        "map",
        "place",
        "portrait",
        "chart",
        "diagram",
        "music",
        "speech",
        "document",
        "performance",
        "architecture",
        "institution",
        "pressure_system",
        "symbolic_artifact"
      ]
    },
    "local_vault_path": {
      "type": "string",
      "minLength": 1
    },
    "shared_cloud_path": {
      "type": "string",
      "minLength": 1
    },
    "provenance": {
      "type": "string",
      "minLength": 1
    },
    "source_name": {
      "type": "string",
      "minLength": 1
    },
    "rights_status": {
      "type": "string",
      "enum": [
        "public_domain",
        "open_license",
        "institutional_terms",
        "permission_required",
        "permission_received",
        "restricted",
        "unknown"
      ]
    },
    "date_or_period": {
      "type": "string"
    },
    "place_or_culture": {
      "type": "string"
    },
    "what_to_notice": {
      "type": "string",
      "minLength": 1
    },
    "lecture_connection": {
      "type": "string",
      "minLength": 1
    },
    "limit_or_caution": {
      "type": "string",
      "minLength": 1
    },
    "curator_note": {
      "type": "string",
      "minLength": 1
    }
  }
}
